{
  "scopeName": "source.sql.blaze",
  "name": "Blaze SQL",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-dash.sql", "match": "--.*$" },
        { "name": "comment.block.sql", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.single.sql", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.sql", "match": "''" }] }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.sql", "match": "\\b\\d+(\\.\\d+)?\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.other.DDL.sql", "match": "(?i)\\b(CREATE|ALTER|DROP|TRUNCATE|TABLE|VIEW|INDEX|SCHEMA|DATABASE)\\b" },
        { "name": "keyword.other.DML.sql", "match": "(?i)\\b(SELECT|INSERT|UPDATE|DELETE|MERGE|COPY|INTO|FROM|WHERE|SET|VALUES)\\b" },
        { "name": "keyword.other.sql", "match": "(?i)\\b(JOIN|INNER|LEFT|RIGHT|FULL|OUTER|CROSS|SEMI|ANTI|ON|USING)\\b" },
        { "name": "keyword.other.sql", "match": "(?i)\\b(GROUP|ORDER|BY|HAVING|LIMIT|OFFSET|ASC|DESC|DISTINCT|ALL)\\b" },
        { "name": "keyword.other.sql", "match": "(?i)\\b(AND|OR|NOT|IN|BETWEEN|LIKE|IS|NULL|TRUE|FALSE|CASE|WHEN|THEN|ELSE|END)\\b" },
        { "name": "keyword.other.sql", "match": "(?i)\\b(AS|WITH|UNION|INTERSECT|EXCEPT|EXISTS|EXPLAIN|ANALYZE)\\b" },
        { "name": "keyword.other.sql", "match": "(?i)\\b(BEGIN|COMMIT|ROLLBACK|SAVEPOINT|TRANSACTION)\\b" },
        { "name": "storage.type.sql", "match": "(?i)\\b(INT|BIGINT|SMALLINT|TINYINT|FLOAT|DOUBLE|DECIMAL|NUMERIC|VARCHAR|TEXT|CHAR|BOOLEAN|DATE|TIMESTAMP|TIME|BLOB|JSON|VECTOR)\\b" },
        { "name": "keyword.other.sql", "match": "(?i)\\b(OVER|PARTITION|ROWS|RANGE|GROUPS|UNBOUNDED|PRECEDING|FOLLOWING|CURRENT|ROW|WINDOW)\\b" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "support.function.aggregate.sql", "match": "(?i)\\b(COUNT|SUM|AVG|MIN|MAX|ARRAY_AGG|STRING_AGG)\\b" },
        { "name": "support.function.window.sql", "match": "(?i)\\b(ROW_NUMBER|RANK|DENSE_RANK|NTILE|LAG|LEAD|FIRST_VALUE|LAST_VALUE|NTH_VALUE|PERCENT_RANK|CUME_DIST)\\b" },
        { "name": "support.function.scalar.sql", "match": "(?i)\\b(UPPER|LOWER|TRIM|LTRIM|RTRIM|LENGTH|CONCAT|SUBSTRING|REPLACE|REVERSE|ABS|ROUND|CEIL|FLOOR|SQRT|POWER|COALESCE|NULLIF|CAST|EXTRACT|DATE_TRUNC|NOW|CURRENT_DATE|CURRENT_TIMESTAMP)\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.comparison.sql", "match": "(=|<>|!=|<=|>=|<|>)" },
        { "name": "keyword.operator.arithmetic.sql", "match": "(\\+|-|\\*|/|%)" },
        { "name": "keyword.operator.concatenation.sql", "match": "\\|\\|" }
      ]
    }
  }
}
