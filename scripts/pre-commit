#!/bin/sh
# Pre-commit hook: ensures code is formatted before committing.
# Install with: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or run: make setup

set -e

echo "Running cargo fmt --check..."
if ! cargo fmt --check 2>/dev/null; then
    echo ""
    echo "❌ Code is not formatted. Run 'cargo fmt' before committing."
    exit 1
fi

echo "Running cargo clippy -- -D warnings..."
if ! cargo clippy -- -D warnings 2>/dev/null; then
    echo ""
    echo "❌ Clippy found warnings. Run 'make fix' to auto-fix, or address manually."
    exit 1
fi

echo "✅ Pre-commit checks passed."
